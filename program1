import java.util.*;

class primeNumber{
    public static void main(String[] args){
        System.out.println("THE PRIME NUMBER BETWEEN 1 TO 100");
        for(int n=2;n<=100;n++){
            Boolean isprime = true;
            for(int i =2;i<=n/2;i++){
                if(n%i==0){
                    isprime = false;
                    break;
                }
            }
            if(isprime){
                    System.out.print(n+",");
                }
        }
    }
}
