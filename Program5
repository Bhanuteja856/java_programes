import java.util.*;
// import java.Array
class program5{
    public static void main(String[] args){
        Scanner scan = new Scanner(System.in);
        int n = scan.nextInt();
        int[] arr = new int[n];
        for(int i = 0;i<n;i++){arr[i]=scan.nextInt();}
        Arrays.sort(arr);
        System.out.println("Maximum : "+arr[n-1]);
        System.out.println("Minimum : "+arr[0]);
    }
}
