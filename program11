	    int max_count = 0;
	    char max_char = ' ';
	    for(auto i : s){
	        int cnt = 0;
	        for(char j : s){
	            if(i==s){
	                cnt++;
	            }
	        }
	        if(cnt >= max_count){
	            max_count = cnt;
	            max_char = i;
	        }
	    }
	    System.out.println("THE MAX COUNT IS : "+max_count);
